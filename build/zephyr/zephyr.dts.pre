    <((((((0) * 32U) + (11)) & 0x1FFU) << 0U) | ((3U & 0xFFU) << 24U))>;
  };
 };

 uart0_sleep: uart0_sleep {
  group1 {
   psels = <((((((0) * 32U) + (6)) & 0x1FFU) << 0U) | ((0U & 0xFFU) << 24U))>,
    <((((((0) * 32U) + (8)) & 0x1FFU) << 0U) | ((1U & 0xFFU) << 24U))>,
    <((((((0) * 32U) + (7)) & 0x1FFU) << 0U) | ((2U & 0xFFU) << 24U))>,
    <((((((0) * 32U) + (11)) & 0x1FFU) << 0U) | ((3U & 0xFFU) << 24U))>;
   low-power-enable;
  };
 };

 uart1_default: uart1_default {
  group1 {
   psels = <((((((1) * 32U) + (1)) & 0x1FFU) << 0U) | ((0U & 0xFFU) << 24U))>,
