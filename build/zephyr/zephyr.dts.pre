   psels = <((((((1) * 32U) + (1)) & 0x1FFU) << 0U) | ((0U & 0xFFU) << 24U))>,
    <((((((1) * 32U) + (2)) & 0x1FFU) << 0U) | ((1U & 0xFFU) << 24U))>;
   low-power-enable;
  };
 };

 i2c1_default: i2c1_default {
  group1 {
   psels = <((((((0) * 32U) + (14)) & 0x1FFU) << 0U) | ((12U & 0xFFU) << 24U))>,
    <((((((0) * 32U) + (13)) & 0x1FFU) << 0U) | ((11U & 0xFFU) << 24U))>;
